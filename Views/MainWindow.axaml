<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VisualDataDiff.ViewModels"
        xmlns:tg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.TreeDataGrid"
        xmlns:tgp="clr-namespace:Avalonia.Controls.Primitives;assembly=Avalonia.Controls.TreeDataGrid"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1600"
        d:DesignHeight="900"
        x:Class="VisualDataDiff.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Visual Data Diff"
        DragDrop.AllowDrop="True">

    <Window.Styles>
        <Style Selector="tgp|TreeDataGridRow">
            <Setter Property="Height" Value="24"/>
        </Style>
        <Style Selector="tgp|TreeDataGridCell[IsSelected=True]">
            <Setter Property="BorderBrush" Value="#FF3E9BFF"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="Border.nameMismatch">
            <Setter Property="Background" Value="#4DB33A2E"/>
            <Setter Property="BorderBrush" Value="#FFD9603C"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.searchAllRow">
            <Setter Property="Background" Value="#FF3A3A3D"/>
        </Style>
        <Style Selector="ItemsControl.delimitedTextPreview TextBlock">
            <Setter Property="FontFamily" Value="Consolas,Menlo,monospace"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>
    </Window.Styles>

    <Panel>
    <Grid RowDefinitions="Auto,Auto,*" Margin="8" RowSpacing="8">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="8">
            <GroupBox Grid.Column="0" Header="Visibility">
                <Grid Margin="8" ColumnDefinitions="*,Auto,*" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock FontWeight="Bold" Text="Column Visibility"/>
                        <CheckBox IsChecked="{Binding HideIdenticalColumns}" Content="Hide Identical Columns"/>
                        <CheckBox IsVisible="{Binding ShowHideIdenticalKeyColumnsOption}"
                                  IsChecked="{Binding HideIdenticalKeyColumns}"
                                  Content="Also hide identical key columns"/>
                        <CheckBox IsChecked="{Binding HideIgnoredColumns}" Content="Hide ignored columns"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Width="1"
                            Margin="4,0"
                            Background="Gray"/>

                    <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock FontWeight="Bold" Text="Row Visibility"/>
                        <ComboBox MinWidth="220"
                                  ItemsSource="{Binding AvailableRowVisibilityOptions}"
                                  SelectedItem="{Binding SelectedRowVisibilityOption}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Disabled: per-column editing on the main screen has been replaced by the
                 Column Setup popover. Kept for potential reuse later.
            <GroupBox Grid.Column="1" Header="{Binding ColumnOptionsHeader}">
                <Border Margin="8" IsVisible="{Binding HasSelectedColumnOption}">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="20" RowSpacing="8">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock VerticalAlignment="Center" Text="Type"/>
                            <ComboBox ItemsSource="{Binding SelectedColumnOption.AvailableRoles}"
                                      SelectedItem="{Binding SelectedColumnOption.Role}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <CheckBox IsChecked="{Binding SelectedColumnOption.CaseSensitive}"
                                      Content="Case-sensitive"/>
                            <CheckBox IsChecked="{Binding SelectedColumnOption.IgnoreLeadingAndTrailingWhitespace}"
                                      Content="Ignore leading/trailing whitespace"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </GroupBox>
            -->
            <GroupBox Grid.Column="1" Header="Actions">
                <Grid Margin="8" RowDefinitions="Auto,Auto" RowSpacing="6">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <Button Content="Reload" Command="{Binding ReloadCommand}"/>
                        <Button Content="Column Setup..." Command="{Binding OpenColumnSettingsCommand}"/>
                        <Button Content="Search (Ctrl+F)" Command="{Binding OpenSearchCommand}"/>
                        <Button Content="Cancel" Command="{Binding CancelCommand}"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Text="{Binding StatusText}" TextWrapping="Wrap"/>
                </Grid>
            </GroupBox>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8">
            <GroupBox Grid.Column="0" Header="Left Source">
                <Grid Margin="8" ColumnDefinitions="Auto,180,*,Auto,Auto" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Source Type"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableSourceTypes}" SelectedItem="{Binding LeftSource.SelectedSourceTypeOption}"/>
                    <CheckBox Grid.Column="2"
                              VerticalAlignment="Center"
                              IsVisible="{Binding LeftSource.SupportsHeaderOption}"
                              IsChecked="{Binding LeftSource.TreatFirstRowAsHeader}"
                              Content="Treat first row as header names"/>
                    <Button Grid.Column="3" Content="Setup Source" Command="{Binding SetupLeftSourceCommand}"/>
                    <Button Grid.Column="4"
                            Content="Configure..."
                            IsVisible="{Binding LeftSource.SupportsDelimiterConfiguration}"
                            Command="{Binding ConfigureLeftSourceCommand}"/>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Right Source">
                <Grid Margin="8" ColumnDefinitions="Auto,180,*,Auto,Auto" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Source Type"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableSourceTypes}" SelectedItem="{Binding RightSource.SelectedSourceTypeOption}"/>
                    <CheckBox Grid.Column="2"
                              VerticalAlignment="Center"
                              IsVisible="{Binding RightSource.SupportsHeaderOption}"
                              IsChecked="{Binding RightSource.TreatFirstRowAsHeader}"
                              Content="Treat first row as header names"/>
                    <Button Grid.Column="3" Content="Setup Source" Command="{Binding SetupRightSourceCommand}"/>
                    <Button Grid.Column="4"
                            Content="Configure..."
                            IsVisible="{Binding RightSource.SupportsDelimiterConfiguration}"
                            Command="{Binding ConfigureRightSourceCommand}"/>
                </Grid>
            </GroupBox>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="8" IsVisible="{Binding !IsAnyOverlayOpen}">
            <GroupBox x:Name="LeftSourceGroupBox" Grid.Column="0" Header="{Binding LeftSource.DataGroupHeader}">
                <Grid Margin="4" RowDefinitions="*,Auto" RowSpacing="6">
                    <tg:TreeDataGrid Grid.Row="0"
                                     x:Name="LeftTreeDataGrid"/>
                    <TextBlock Grid.Row="1" Margin="4,0,4,2" Text="{Binding LeftGridSummary}"/>
                </Grid>
            </GroupBox>

            <GroupBox x:Name="RightSourceGroupBox" Grid.Column="1" Header="{Binding RightSource.DataGroupHeader}">
                <Grid Margin="4" RowDefinitions="*,Auto" RowSpacing="6">
                    <tg:TreeDataGrid Grid.Row="0"
                                     x:Name="RightTreeDataGrid"/>
                    <TextBlock Grid.Row="1" Margin="4,0,4,2" Text="{Binding RightGridSummary}"/>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>

    <Border IsVisible="{Binding IsPivotOpen}"
            Background="#CC101010">
        <Border Background="#FF2D2D30"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="6"
                Margin="24"
                Padding="16">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="8">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{Binding PivotHeaderText}" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="{Binding PivotSubtitle}" Opacity="0.7" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="4" IsVisible="{Binding IsSearchMode}">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                        <TextBox Grid.Column="0"
                                 x:Name="SearchTextBox"
                                 Text="{Binding SearchText}"
                                 PlaceholderText="Search..."/>
                        <CheckBox Grid.Column="1" Content=".*" ToolTip.Tip="Regular expression" IsChecked="{Binding SearchUseRegex}"/>
                        <CheckBox Grid.Column="2" Content="Aa" ToolTip.Tip="Case sensitive" IsChecked="{Binding SearchCaseSensitive}"/>
                    </Grid>
                    <TextBlock Text="Invalid regular expression"
                               Foreground="#FFE0A15B"
                               IsVisible="{Binding SearchHasRegexError}"/>
                </StackPanel>

                <Grid Grid.Row="2" RowDefinitions="Auto,Auto,Auto" RowSpacing="4" IsVisible="{Binding IsSearchMode}">
                    <Grid Grid.Row="0" ColumnDefinitions="24,220,80,80,80" ColumnSpacing="8">
                        <TextBlock Grid.Column="1" Text="Column" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="Left" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="Right" FontWeight="Bold"/>
                        <TextBlock Grid.Column="4" Text="Total" FontWeight="Bold"/>
                    </Grid>
                    <ScrollViewer Grid.Row="1" MaxHeight="160">
                        <ItemsControl ItemsSource="{Binding SearchColumnFilters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SearchColumnFilterViewModel">
                                    <Border Classes.searchAllRow="{Binding IsAll}" Padding="2">
                                        <Grid ColumnDefinitions="24,220,80,80,80" ColumnSpacing="8">
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsIncluded}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ColumnName}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding LeftCount}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="{Binding RightCount}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="{Binding TotalCount}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="After filter:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SearchAfterFilterLeftCount, StringFormat='Left {0}'}"/>
                        <TextBlock Text="{Binding SearchAfterFilterRightCount, StringFormat='Right {0}'}"/>
                        <TextBlock Text="{Binding SearchAfterFilterTotalCount, StringFormat='Total {0}'}"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <Button Content="▲ Previous Row (↑)" Command="{Binding PivotPreviousRowCommand}"/>
                        <Button Content="▼ Next Row (↓)" Command="{Binding PivotNextRowCommand}"/>
                        <CheckBox Content="Skip orphan rows" IsChecked="{Binding PivotSkipOrphanRows}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                        <CheckBox Content="Show all columns" IsChecked="{Binding PivotShowAllColumns}"/>
                        <Button Content="Close (Esc)" Command="{Binding ClosePivotViewCommand}"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="4" ColumnDefinitions="220,*,*" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" Text="Column" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="{Binding LeftSource.DataGroupHeader}" FontWeight="Bold"/>
                    <TextBlock Grid.Column="2" Text="{Binding RightSource.DataGroupHeader}" FontWeight="Bold"/>
                </Grid>

                <ScrollViewer Grid.Row="5">
                    <ItemsControl ItemsSource="{Binding PivotedColumns}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PivotedColumnViewModel">
                                <Grid ColumnDefinitions="220,*,*" ColumnSpacing="8" Margin="0,0,0,2">
                                    <Border Grid.Column="0" Padding="4,2" Background="#FF3A3A3D">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{Binding ColumnName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="(key)" Opacity="0.7" IsVisible="{Binding IsKeyColumn}"/>
                                        </StackPanel>
                                    </Border>
                                    <ContentControl Grid.Column="1"
                                                    Content="{Binding LeftCell}"
                                                    ContentTemplate="{StaticResource DiffCellTemplate}"/>
                                    <ContentControl Grid.Column="2"
                                                    Content="{Binding RightCell}"
                                                    ContentTemplate="{StaticResource DiffCellTemplate}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Border>

    <Border IsVisible="{Binding IsColumnSettingsOpen}"
            Background="#CC101010">
        <Border Background="#FF2D2D30"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="6"
                Margin="24"
                Padding="16">
            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="8">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Column Setup" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="Review column types and confirm the left/right headers line up."
                               Opacity="0.7" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Row="1"
                           Text="Select at least one Key column before running the comparison."
                           Foreground="#FFE0A15B"
                           FontWeight="SemiBold"
                           IsVisible="{Binding !HasKeyColumnSelected}"/>

                <Grid Grid.Row="2" ColumnDefinitions="40,130,120,190,*,*" ColumnSpacing="12" Margin="0,0,16,2">
                    <TextBlock Grid.Column="0" Text="#" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Type" FontWeight="Bold"/>
                    <TextBlock Grid.Column="2" Text="Case-sensitive" FontWeight="Bold"/>
                    <TextBlock Grid.Column="3" Text="Trim leading/trailing whitespace" FontWeight="Bold" TextWrapping="Wrap"/>
                    <TextBlock Grid.Column="4" Text="{Binding LeftSource.DataGroupHeader}" FontWeight="Bold"/>
                    <TextBlock Grid.Column="5" Text="{Binding RightSource.DataGroupHeader}" FontWeight="Bold"/>
                </Grid>

                <ScrollViewer Grid.Row="3">
                    <ItemsControl ItemsSource="{Binding ColumnOptions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ColumnOptionsViewModel">
                                <Grid ColumnDefinitions="40,130,120,190,*,*" ColumnSpacing="12" Margin="0,0,0,4">
                                    <TextBlock Grid.Column="0" Text="{Binding Ordinal}" VerticalAlignment="Center" Opacity="0.6"/>
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableRoles}" SelectedItem="{Binding Role}"/>
                                    <CheckBox Grid.Column="2" IsChecked="{Binding CaseSensitive}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Column="3" IsChecked="{Binding IgnoreLeadingAndTrailingWhitespace}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border Grid.Column="4" Padding="4,2" CornerRadius="3" Classes.nameMismatch="{Binding HasNameMismatch}">
                                        <TextBlock Text="{Binding LeftDisplayName}" TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <Border Grid.Column="5" Padding="4,2" CornerRadius="3" Classes.nameMismatch="{Binding HasNameMismatch}">
                                        <TextBlock Text="{Binding RightDisplayName}" TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                    <TextBlock Grid.Column="0"
                               Text="Header names highlighted above differ between the left and right file (ignoring case and whitespace)."
                               Opacity="0.6" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" IsVisible="{Binding !IsConfirmingDiscardColumnSettings}">
                        <Button Content="OK" Command="{Binding ColumnSettingsOkCommand}"/>
                        <Button Content="Cancel (Esc)" Command="{Binding ColumnSettingsCancelCommand}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsConfirmingDiscardColumnSettings}">
                        <TextBlock Text="Discard changes?" VerticalAlignment="Center" Foreground="#FFE0A15B" Margin="0,0,4,0"/>
                        <Button Content="Discard" Command="{Binding DiscardColumnSettingsChangesCommand}"/>
                        <Button Content="Keep Editing" Command="{Binding KeepEditingColumnSettingsCommand}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Border>

    <Border IsVisible="{Binding IsDelimitedTextConfigOpen}"
            Background="#CC101010">
        <Border Background="#FF2D2D30"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="6"
                Margin="24"
                Padding="16"
                MaxWidth="720"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,200,Auto" RowSpacing="10">
                <TextBlock Grid.Row="0" Text="{Binding DelimitedTextConfigTitle}" FontWeight="Bold" FontSize="16"/>

                <Grid Grid.Row="1" ColumnDefinitions="Auto,160,Auto,120" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" Text="Delimiter" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableDelimiterPresets}" SelectedItem="{Binding SelectedDelimiterPreset}"/>
                    <TextBox Grid.Column="3"
                             IsVisible="{Binding IsCustomDelimiterVisible}"
                             Text="{Binding CustomDelimiterText}"
                             MaxLength="1"
                             PlaceholderText="char"/>
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="Auto,160,Auto,120" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" Text="Quote / literal character" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableQuotePresets}" SelectedItem="{Binding SelectedQuotePreset}"/>
                    <TextBox Grid.Column="3"
                             IsVisible="{Binding IsCustomQuoteVisible}"
                             Text="{Binding CustomQuoteText}"
                             MaxLength="1"
                             PlaceholderText="char"/>
                </Grid>

                <TextBlock Grid.Row="3"
                           Text="{Binding DelimitedTextConfigErrorText}"
                           Foreground="#FFE0A15B"
                           IsVisible="{Binding HasDelimitedTextConfigError}"/>

                <Border Grid.Row="4" Background="#FF1E1E1E" Padding="8" CornerRadius="4">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding DelimitedTextPreviewLines}" Classes="delimitedTextPreview"/>
                    </ScrollViewer>
                </Border>

                <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="OK" Command="{Binding DelimitedTextConfigOkCommand}"/>
                    <Button Content="Cancel (Esc)" Command="{Binding DelimitedTextConfigCancelCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
    </Panel>
</Window>
