<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VisualDataDiff.ViewModels"
        xmlns:tg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.TreeDataGrid"
        xmlns:tgp="clr-namespace:Avalonia.Controls.Primitives;assembly=Avalonia.Controls.TreeDataGrid"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1600"
        d:DesignHeight="900"
        x:Class="VisualDataDiff.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Visual Data Diff">

    <Window.Styles>
        <Style Selector="tgp|TreeDataGridRow">
            <Setter Property="Height" Value="24"/>
        </Style>
        <Style Selector="tgp|TreeDataGridCell[IsSelected=True]">
            <Setter Property="BorderBrush" Value="#FF3E9BFF"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </Window.Styles>

    <Panel>
    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="8" RowSpacing="8">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="8">
            <GroupBox Grid.Column="0" Header="Visibility">
                <Grid Margin="8" ColumnDefinitions="*,Auto,*" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock FontWeight="Bold" Text="Column Visibility"/>
                        <CheckBox IsChecked="{Binding HideIdenticalColumns}" Content="Hide Identical Columns"/>
                        <CheckBox IsVisible="{Binding ShowHideIdenticalKeyColumnsOption}"
                                  IsChecked="{Binding HideIdenticalKeyColumns}"
                                  Content="Also hide identical key columns"/>
                        <CheckBox IsChecked="{Binding HideIgnoredColumns}" Content="Hide ignored columns"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Width="1"
                            Margin="4,0"
                            Background="Gray"/>

                    <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock FontWeight="Bold" Text="Row Visibility"/>
                        <ComboBox MinWidth="220"
                                  ItemsSource="{Binding AvailableRowVisibilityOptions}"
                                  SelectedItem="{Binding SelectedRowVisibilityOption}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="{Binding ColumnOptionsHeader}">
                <Border Margin="8" IsVisible="{Binding HasSelectedColumnOption}">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="20" RowSpacing="8">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock VerticalAlignment="Center" Text="Type"/>
                            <ComboBox ItemsSource="{Binding SelectedColumnOption.AvailableRoles}"
                                      SelectedItem="{Binding SelectedColumnOption.Role}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <CheckBox IsChecked="{Binding SelectedColumnOption.CaseSensitive}"
                                      Content="Case-sensitive"/>
                            <CheckBox IsChecked="{Binding SelectedColumnOption.IgnoreLeadingAndTrailingWhitespace}"
                                      Content="Ignore leading/trailing whitespace"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </GroupBox>
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto,Auto" RowSpacing="4">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                <Button Content="Load + Compare" Command="{Binding LoadAndCompareCommand}"/>
                <Button Content="Recompare with current column options" Command="{Binding RecompareCommand}"/>
                <Button Content="Cancel" Command="{Binding CancelCommand}"/>
            </StackPanel>
            <TextBlock Grid.Row="1" Text="{Binding StatusText}" TextWrapping="Wrap"/>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="8">
            <GroupBox Grid.Column="0" Header="Left Source">
                <Grid Margin="8" ColumnDefinitions="Auto,180,*,Auto" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Source Type"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableSourceTypes}" SelectedItem="{Binding LeftSource.SelectedSourceType}"/>
                    <CheckBox Grid.Column="2"
                              VerticalAlignment="Center"
                              IsVisible="{Binding LeftSource.SupportsHeaderOption}"
                              IsChecked="{Binding LeftSource.TreatFirstRowAsHeader}"
                              Content="Treat first row as header names"/>
                    <Button Grid.Column="3" Content="Setup Source" Command="{Binding SetupLeftSourceCommand}"/>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Right Source">
                <Grid Margin="8" ColumnDefinitions="Auto,180,*,Auto" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Source Type"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableSourceTypes}" SelectedItem="{Binding RightSource.SelectedSourceType}"/>
                    <CheckBox Grid.Column="2"
                              VerticalAlignment="Center"
                              IsVisible="{Binding RightSource.SupportsHeaderOption}"
                              IsChecked="{Binding RightSource.TreatFirstRowAsHeader}"
                              Content="Treat first row as header names"/>
                    <Button Grid.Column="3" Content="Setup Source" Command="{Binding SetupRightSourceCommand}"/>
                </Grid>
            </GroupBox>
        </Grid>

        <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="8" IsVisible="{Binding !IsPivotOpen}">
            <GroupBox Grid.Column="0" Header="{Binding LeftSource.DataGroupHeader}">
                <Grid Margin="4" RowDefinitions="*,Auto" RowSpacing="6">
                    <tg:TreeDataGrid Grid.Row="0"
                                     x:Name="LeftTreeDataGrid"/>
                    <TextBlock Grid.Row="1" Margin="4,0,4,2" Text="{Binding LeftGridSummary}"/>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="{Binding RightSource.DataGroupHeader}">
                <Grid Margin="4" RowDefinitions="*,Auto" RowSpacing="6">
                    <tg:TreeDataGrid Grid.Row="0"
                                     x:Name="RightTreeDataGrid"/>
                    <TextBlock Grid.Row="1" Margin="4,0,4,2" Text="{Binding RightGridSummary}"/>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>

    <Border IsVisible="{Binding IsPivotOpen}"
            Background="#CC101010">
        <Border Background="#FF2D2D30"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="6"
                Margin="24"
                Padding="16">
            <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Pivoted Row View" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="{Binding PivotSubtitle}" Opacity="0.7" VerticalAlignment="Center"/>
                </StackPanel>

                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <Button Content="▲ Previous Row (↑)" Command="{Binding PivotPreviousRowCommand}"/>
                        <Button Content="▼ Next Row (↓)" Command="{Binding PivotNextRowCommand}"/>
                        <CheckBox Content="Skip orphan rows" IsChecked="{Binding PivotSkipOrphanRows}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                        <CheckBox Content="Show all columns" IsChecked="{Binding PivotShowAllColumns}"/>
                        <Button Content="Close (Esc)" Command="{Binding ClosePivotViewCommand}"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="220,*,*" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" Text="Column" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="{Binding LeftSource.DataGroupHeader}" FontWeight="Bold"/>
                    <TextBlock Grid.Column="2" Text="{Binding RightSource.DataGroupHeader}" FontWeight="Bold"/>
                </Grid>

                <ScrollViewer Grid.Row="3">
                    <ItemsControl ItemsSource="{Binding PivotedColumns}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PivotedColumnViewModel">
                                <Grid ColumnDefinitions="220,*,*" ColumnSpacing="8" Margin="0,0,0,2">
                                    <Border Grid.Column="0" Padding="4,2" Background="#FF3A3A3D">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{Binding ColumnName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="(key)" Opacity="0.7" IsVisible="{Binding IsKeyColumn}"/>
                                        </StackPanel>
                                    </Border>
                                    <ContentControl Grid.Column="1"
                                                    Content="{Binding LeftCell}"
                                                    ContentTemplate="{StaticResource DiffCellTemplate}"/>
                                    <ContentControl Grid.Column="2"
                                                    Content="{Binding RightCell}"
                                                    ContentTemplate="{StaticResource DiffCellTemplate}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Border>
    </Panel>
</Window>
